# AI Provider: "ollama" (local) or "anthropic" (cloud)
AI_PROVIDER=ollama

# Ollama (local)
OLLAMA_HOST=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
LLM_MODEL=llama3.2

# Anthropic / Claude (optional, for future use)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_EMBEDDING_MODEL=voyage-3
# ANTHROPIC_LLM_MODEL=claude-sonnet-4-6

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Timeouts (Sekunden). OLLAMA_TIMEOUT leer lassen für kein Timeout (Overnight-Jobs).
# OLLAMA_TIMEOUT=
OLLAMA_EMBED_TIMEOUT=120

# Upload & Batch
MAX_UPLOAD_SIZE_MB=50
BATCH_CONCURRENCY=3

# App
LOG_LEVEL=INFO
